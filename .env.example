# .env.example — kopyala: .env.local ; Supabase proje ayarlarından doldur
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
# Yalnızca sunucu tarafı gerekirse (seed/yönetim betikleri; istemciye asla sızdırma)
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY

# E-posta bildirimleri (Resend) — anahtar yoksa bildirimler sessizce atlanır
RESEND_API_KEY=re_YOUR_KEY
ADMIN_EMAIL=admin@example.com
EMAIL_FROM=Axis Akademi <noreply@example.com>
